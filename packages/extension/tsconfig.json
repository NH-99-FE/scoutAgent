{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "types": ["node", "mocha"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src"]
}
