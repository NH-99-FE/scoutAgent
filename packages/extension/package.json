{
  "name": "@scout-agent/extension",
  "displayName": "Scout Agent",
  "description": "AI Coding Agent — Chat-driven dev, code gen & edit, context-aware suggest, diagnose & fix",
  "version": "0.0.1",
  "type": "module",
  "publisher": "",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Chat"
  ],
  "activationEvents": [
    "onView:scout-agent.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "scout-agent",
          "title": "Scout Agent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "scout-agent": [
        {
          "type": "webview",
          "id": "scout-agent.sidebar",
          "name": "Scout Agent"
        }
      ]
    },
    "commands": [
      {
        "command": "scout-agent.openSidebar",
        "title": "Open Scout Agent"
      }
    ],
    "configuration": {
      "title": "Scout Agent",
      "properties": {
        "scout-agent.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude models"
        },
        "scout-agent.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for GPT models"
        },
        "scout-agent.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default model ID (e.g. claude-sonnet-4-20250514, gpt-4o)"
        },
        "scout-agent.defaultThinkingLevel": {
          "type": "string",
          "enum": [
            "off",
            "minimal",
            "low",
            "medium",
            "high"
          ],
          "default": "off",
          "description": "Default thinking level for reasoning models"
        },
        "scout-agent.transport": {
          "type": "string",
          "enum": [
            "sse",
            "websocket",
            "websocket-cached",
            "auto"
          ],
          "default": "auto",
          "description": "Preferred provider transport when supported"
        },
        "scout-agent.thinkingBudgets": {
          "type": "object",
          "default": {},
          "description": "Custom token budgets for thinking levels"
        },
        "scout-agent.websocketConnectTimeoutMs": {
          "type": "number",
          "description": "WebSocket connect/open handshake timeout in milliseconds; 0 disables it"
        },
        "scout-agent.shellPath": {
          "type": "string",
          "default": "",
          "description": "Path to the shell executable (leave empty for system default)"
        },
        "scout-agent.retry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic session retry for transient assistant errors"
        },
        "scout-agent.retry.maxRetries": {
          "type": "number",
          "default": 3,
          "description": "Maximum automatic session retry attempts"
        },
        "scout-agent.retry.baseDelayMs": {
          "type": "number",
          "default": 2000,
          "description": "Base delay in milliseconds for automatic session retry"
        },
        "scout-agent.retry.provider.timeoutMs": {
          "type": "number",
          "description": "Provider request timeout in milliseconds"
        },
        "scout-agent.retry.provider.maxRetries": {
          "type": "number",
          "description": "Maximum provider request retry attempts"
        },
        "scout-agent.retry.provider.maxRetryDelayMs": {
          "type": "number",
          "default": 60000,
          "description": "Maximum provider retry delay in milliseconds"
        },
        "scout-agent.compaction.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic context compaction"
        },
        "scout-agent.compaction.reserveTokens": {
          "type": "number",
          "default": 16384,
          "description": "Token budget reserved for new content after compaction"
        },
        "scout-agent.compaction.keepRecentTokens": {
          "type": "number",
          "default": 20000,
          "description": "Number of recent tokens to keep during compaction"
        },
        "scout-agent.branchSummary.reserveTokens": {
          "type": "number",
          "default": 16384,
          "description": "Token budget reserved when summarizing an abandoned session tree branch"
        },
        "scout-agent.branchSummary.skipPrompt": {
          "type": "boolean",
          "default": false,
          "description": "When true, future Webview tree navigation should default to navigating without asking to summarize the abandoned branch"
        },
        "scout-agent.steeringMode": {
          "type": "string",
          "enum": [
            "one-at-a-time",
            "all"
          ],
          "default": "one-at-a-time",
          "description": "How steering messages are queued: one-at-a-time processes one per turn, all processes all queued messages"
        },
        "scout-agent.followUpMode": {
          "type": "string",
          "enum": [
            "one-at-a-time",
            "all"
          ],
          "default": "one-at-a-time",
          "description": "How follow-up messages are queued: one-at-a-time processes one per turn, all processes all queued messages"
        },
        "scout-agent.extensionPaths": {
          "type": "array",
          "default": [],
          "description": "Additional paths to load Scout extensions from"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@scout-agent/agent": "workspace:*",
    "@scout-agent/ai": "workspace:*",
    "@scout-agent/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.0",
    "diff": "^9.0.0",
    "yaml": "^2.9.0",
    "ignore": "^6.0.0",
    "jiti": "^2.4.2"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.9.1",
    "@types/diff": "^8.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
